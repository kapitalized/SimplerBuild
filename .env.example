# Copy to .env.local. Base stack: Neon + Neon Auth + Vercel Blob + Drizzle.

# BRANDING
NEXT_PUBLIC_APP_NAME=SimplerBuild

# BASE STACK (Neon + Neon Auth + Vercel Blob)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.neon.tech/neondb?sslmode=require
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=
BLOB_READ_WRITE_TOKEN=
# BLOB_ACCESS=public or private — must match your Vercel Blob store. Use "private" for security (recommended).
# BLOB_ACCESS=public
# Optional: fixed app URL so auth/origin matches (e.g. http://localhost:3001). Client uses window.location.origin if unset.
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# PAYLOAD CMS (admin at /admin) — uses same DATABASE_URL
PAYLOAD_SECRET=change-me-in-production

# AI & PYTHON ENGINE
OPENROUTER_API_KEY=
INTERNAL_SERVICE_KEY=dev-secret-handshake
PYTHON_ENGINE_URL=http://localhost:8000
# Optional: Hugging Face (see docs/HF_HuggingFace_Model_Setup.md). Leave empty to use OpenRouter only.
# HUGGINGFACE_HUB_TOKEN=
# USE_HF_FLOORPLAN_EXTRACTION=false
# Optional: use second-pass review extraction (lib/ai/orchestrator-multilook.ts). Default: single-pass.
# ENABLE_EXTRACTION_REVIEW_PASS=false

# STRIPE (after test mode setup)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs from Stripe Dashboard (Products → Recurring prices)
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=

# CONTACT FORM (Brevo)
BREVO_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
CONTACT_FROM_NAME=

# SECURITY (32 chars for AES-256)
ENCRYPTION_KEY=

# ALTERNATIVE: Supabase (DB + Auth + Storage). Omit base stack vars and set these.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URI=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
