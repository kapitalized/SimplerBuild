# Copy to .env.local and fill in. No external services need to exist yet.

# BRANDING
NEXT_PUBLIC_APP_NAME=ConstructAI

# SUPABASE (after creating project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PAYLOAD CMS (admin at /admin)
PAYLOAD_SECRET=change-me-in-production
# Postgres (Supabase connection string from Project Settings → Database)
DATABASE_URI=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# AI & PYTHON ENGINE
OPENROUTER_API_KEY=
INTERNAL_SERVICE_KEY=dev-secret-handshake
PYTHON_ENGINE_URL=http://localhost:8000

# STRIPE (after test mode setup)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# SECURITY (32 chars for AES-256)
ENCRYPTION_KEY=
